# Groq API Keys (required for LLM)
# Get free key from: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Backup keys (optional - for fallback on rate limit)
GROQ_API_KEY_2=
GROQ_API_KEY_3=

# Groq Model (default: llama-3.3-70b-versatile)
GROQ_MODEL=llama-3.3-70b-versatile

# Brain model for query classification
GROQ_BRAIN_MODEL=llama-3.1-8b-instant

# Tavily API Key (optional - for web search)
# Get free key from: https://tavily.com
TAVILY_API_KEY=your_tavily_api_key_here

# TTS Voice (optional)
# List voices: edge-tts --list-voices
TTS_VOICE=en-GB-RyanNeural
TTS_RATE=+22%

# Assistant Name
ASSISTANT_NAME=A.D.A
ASTRO_USER_TITLE=Sir
